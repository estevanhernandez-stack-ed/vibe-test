{
  "name": "vibe-test-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Vibe Test — diagnostic-and-retrofit testing plugin for vibe-coded apps. This repo is the canary / edge-release channel; for stable releases install via the 626Labs marketplace at github.com/estevanhernandez-stack-ed/vibe-plugins.",
  "author": "626Labs LLC",
  "license": "MIT",
  "homepage": "https://github.com/estevanhernandez-stack-ed/vibe-test#readme",
  "bugs": "https://github.com/estevanhernandez-stack-ed/vibe-test/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/estevanhernandez-stack-ed/vibe-test.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r --filter=./packages/* build",
    "type-check": "pnpm -r --filter=./packages/* type-check",
    "test": "pnpm -r --filter=./packages/* test",
    "clean": "pnpm -r --filter=./packages/* clean"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.9"
}
