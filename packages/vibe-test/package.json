{
  "name": "@esthernandez/vibe-test",
  "version": "0.2.2",
  "description": "Test analyzer and generator for vibe-coded apps. Classification-driven. Tiered by deployment context. Catches the broken harnesses every other test tool assumes away.",
  "author": "626Labs LLC",
  "license": "MIT",
  "homepage": "https://github.com/estevanhernandez-stack-ed/vibe-plugins#readme",
  "bugs": "https://github.com/estevanhernandez-stack-ed/vibe-plugins/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/estevanhernandez-stack-ed/vibe-plugins.git",
    "directory": "packages/vibe-test"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "skills",
    ".claude-plugin",
    "scripts/postinstall.js",
    "README.md",
    "RESOLVE.md",
    "data-contract.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./state": {
      "types": "./dist/state/index.d.ts",
      "default": "./dist/state/index.js"
    },
    "./scanner": {
      "types": "./dist/scanner/index.d.ts",
      "default": "./dist/scanner/index.js"
    },
    "./coverage": {
      "types": "./dist/coverage/index.d.ts",
      "default": "./dist/coverage/index.js"
    },
    "./reporter": {
      "types": "./dist/reporter/report-object.d.ts",
      "default": "./dist/reporter/report-object.js"
    },
    "./generator": {
      "types": "./dist/generator/index.d.ts",
      "default": "./dist/generator/index.js"
    },
    "./handoff": {
      "types": "./dist/handoff/index.d.ts",
      "default": "./dist/handoff/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    },
    "./composition": {
      "types": "./dist/composition/index.d.ts",
      "default": "./dist/composition/index.js"
    }
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --ext .ts",
    "clean": "rimraf dist .vibe-test"
  },
  "dependencies": {
    "@typescript-eslint/parser": "^7.18.0",
    "@typescript-eslint/typescript-estree": "^7.18.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "c8": "^10.1.3",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.17.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^8.57.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "vibe-plugins",
    "626labs",
    "claude-code-plugin",
    "testing",
    "test-generation",
    "coverage",
    "vibe-coding"
  ]
}
