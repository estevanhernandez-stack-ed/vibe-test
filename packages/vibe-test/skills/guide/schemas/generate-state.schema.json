{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vibe-plugins.626labs.com/schemas/vibe-test/generate-state.schema.json",
  "title": "Vibe Test Generate State",
  "description": "Written at <project>/.vibe-test/state/generate.json. Dry-run variant at last-dry-run.json.",
  "type": "object",
  "required": ["schema_version", "last_updated"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "command": { "type": "string", "const": "generate" },
    "plugin_version": { "type": "string" },
    "last_updated": { "type": "string", "format": "date-time" },
    "scope": { "type": ["string", "null"] },
    "dry_run": { "type": "boolean", "default": false },
    "dry_run_cached_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "For 24h apply-last-dry-run TTL."
    },
    "head_hash_at_generation": {
      "type": ["string", "null"],
      "description": "Recorded for branch-switch check (G3)."
    },
    "framework_used": { "type": "string" },
    "idiom_source_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tests_proposed": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "confidence", "lane"],
        "properties": {
          "path": { "type": "string" },
          "source_under_test": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "lane": {
            "type": "string",
            "enum": ["auto", "staged", "inline"]
          },
          "env_vars_detected": {
            "type": "array",
            "items": { "type": "string" }
          },
          "test_level": {
            "type": "string",
            "enum": ["smoke", "behavioral", "edge", "integration", "performance"]
          },
          "status": {
            "type": "string",
            "enum": ["proposed", "accepted", "rejected", "pending", "applied"]
          },
          "rejection_reason": { "type": ["string", "null"] }
        }
      }
    },
    "tests_accepted": { "type": "integer", "minimum": 0 },
    "tests_rejected": { "type": "integer", "minimum": 0 },
    "tests_staged": { "type": "integer", "minimum": 0 },
    "rejection_reasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "consecutive_reject_count": {
      "type": "integer",
      "minimum": 0,
      "description": "For G4 rejection-pattern probe trigger."
    },
    "runtime_mode": {
      "type": "string",
      "enum": ["static-only", "dev-server", "playwright", "both"]
    },
    "complements_invoked": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
