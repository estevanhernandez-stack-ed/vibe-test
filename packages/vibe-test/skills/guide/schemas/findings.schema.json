{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vibe-plugins.626labs.com/schemas/vibe-test/findings.schema.json",
  "title": "Vibe Sec Findings (consumed by Vibe Test)",
  "description": "Schema for entries in <project>/.vibe-sec/state/findings.jsonl that Vibe Test reads for security-aware generation prioritization (EC5). Owned by Vibe Sec; replicated here for validator availability.",
  "type": "object",
  "required": ["schema_version", "timestamp", "finding_id", "severity", "surface"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "plugin_version": { "type": "string" },
    "finding_id": { "type": "string" },
    "severity": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low", "info"]
    },
    "category": {
      "type": "string",
      "enum": [
        "secret-leak",
        "missing-auth-check",
        "missing-input-validation",
        "missing-authz-check",
        "cve",
        "cors-misconfig",
        "dependency-risk",
        "logging-leak"
      ]
    },
    "surface": {
      "type": "object",
      "required": ["kind", "identifier"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["route", "component", "model", "middleware", "function", "file"]
        },
        "identifier": { "type": "string" },
        "file_path": { "type": "string" },
        "line": { "type": "integer" }
      }
    },
    "remediation": { "type": "string" },
    "test_hint": {
      "type": "string",
      "description": "Suggested test shape Vibe Test should elevate when this finding is present."
    }
  }
}
