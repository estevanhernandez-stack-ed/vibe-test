{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vibe-plugins.626labs.com/schemas/vibe-test/coverage-state.schema.json",
  "title": "Vibe Test Coverage State",
  "description": "Written at <project>/.vibe-test/state/coverage.json.",
  "type": "object",
  "required": ["schema_version", "measured_at", "denominator_honest"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "command": { "type": "string", "const": "coverage" },
    "plugin_version": { "type": "string" },
    "measured_at": { "type": "string", "format": "date-time" },
    "framework": {
      "type": "string",
      "enum": ["vitest", "jest", "mocha", "c8-standalone", "unknown"]
    },
    "adapter_accepted": {
      "type": "boolean",
      "description": "Did the builder accept the adaptation proposal (C1)?"
    },
    "denominator_honest": {
      "type": "boolean",
      "description": "False when cherry-picked coverage is detected."
    },
    "denominator_file_count": { "type": "integer", "minimum": 0 },
    "source_file_count": { "type": "integer", "minimum": 0 },
    "raw_coverage": {
      "type": "object",
      "properties": {
        "lines": { "type": "number" },
        "statements": { "type": "number" },
        "functions": { "type": "number" },
        "branches": { "type": "number" }
      }
    },
    "per_level": {
      "type": "object",
      "properties": {
        "smoke": { "type": "number" },
        "behavioral": { "type": "number" },
        "edge": { "type": "number" },
        "integration": { "type": "number" },
        "performance": { "type": "number" }
      }
    },
    "weighted_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "tier_threshold": { "type": "number", "minimum": 0, "maximum": 100 },
    "passes_tier_threshold": { "type": "boolean" }
  }
}
