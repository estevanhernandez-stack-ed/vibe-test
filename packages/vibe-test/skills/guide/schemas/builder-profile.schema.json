{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vibe-plugins.626labs.com/schemas/vibe-test/builder-profile.schema.json",
  "title": "Vibe Test Builder Profile",
  "description": "The plugins.vibe-test namespace inside ~/.claude/profiles/builder.json. Shared bus fields live under shared.*; plugin-owned fields live under plugins.vibe-test.*.",
  "type": "object",
  "required": [
    "schema_version",
    "testing_experience",
    "preferred_framework",
    "last_updated"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "testing_experience": {
      "type": "string",
      "enum": ["first-time", "beginner", "intermediate", "experienced"]
    },
    "preferred_framework": {
      "type": "string",
      "enum": ["vitest", "jest", "mocha", "playwright", "cypress", "none", "auto"]
    },
    "preferred_assertion_style": {
      "type": "string",
      "enum": ["expect", "assert", "should", "auto"]
    },
    "preferred_test_location": {
      "type": "string",
      "enum": ["colocated", "tests-dir", "__tests__", "auto"]
    },
    "fixture_approach": {
      "type": "string",
      "enum": ["factory", "inline", "json-files", "auto"]
    },
    "auto_generate_threshold": {
      "type": "number",
      "minimum": 0.5,
      "maximum": 1.0,
      "description": "Confidence above which generate auto-writes to tests/ without staging."
    },
    "coverage_target": {
      "oneOf": [
        { "type": "null" },
        { "type": "number", "minimum": 0, "maximum": 100 }
      ],
      "description": "Optional override for computed tier threshold."
    },
    "last_updated": { "type": "string", "format": "date-time" },
    "projects_audited": { "type": "integer", "minimum": 0 },
    "_meta": {
      "type": "object",
      "description": "Per-field Pattern #4 decay metadata.",
      "additionalProperties": {
        "type": "object",
        "required": ["last_confirmed", "stale", "ttl_days"],
        "properties": {
          "last_confirmed": { "type": "string", "format": "date" },
          "stale": { "type": "boolean" },
          "ttl_days": {
            "oneOf": [
              { "type": "integer", "minimum": 1 },
              { "type": "null" }
            ]
          }
        }
      }
    }
  }
}
